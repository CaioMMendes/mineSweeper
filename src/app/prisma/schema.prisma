datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Score {
  id          String   @id @default(uuid())
  playerName  String
  timeMs      Int

  difficulty  Difficulty
  gameVersion String

  createdAt   DateTime @default(now())

  @@index([gameVersion, difficulty, timeMs])
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}
